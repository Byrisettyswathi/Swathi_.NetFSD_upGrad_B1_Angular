@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-5">

    <h1 class="text-center text-primary mb-4">Healthcare Management System</h1>

    <div class="row">

        <!-- Patients -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center">
                    <h3 class="card-title text-success">Patients</h3>
                    <p>Manage patient records</p>
                    <a href="/Patient" class="btn btn-success w-100">Go to Patients</a>
                </div>
            </div>
        </div>

        <!-- Doctors -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center">
                    <h3 class="card-title text-primary">Doctors</h3>
                    <p>Manage doctor details</p>
                    <a href="/Doctor" class="btn btn-primary w-100">Go to Doctors</a>
                </div>
            </div>
        </div>

        <!-- Appointments -->
        <div class="col-md-4">
            <div class="card shadow-lg border-0">
                <div class="card-body text-center">
                    <h3 class="card-title text-warning">Appointments</h3>
                    <p>Book & manage appointments</p>
                    <a href="/Appointment" class="btn btn-warning w-100">Go to Appointments</a>
                </div>
            </div>
        </div>

    </div>

</div>