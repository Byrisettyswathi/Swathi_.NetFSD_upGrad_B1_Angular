@model MVC_ViewModel_Assignment.Models.User;

<h2>Register</h2>

<form asp-action="Register" method="post">

    <input asp-for="Name" placeholder="Name" />
    <span asp-validation-for="Name"></span><br />

    <input asp-for="Email" placeholder="Email" />
    <span asp-validation-for="Email"></span><br />

    <input asp-for="Password" type="password" placeholder="Password" />
    <span asp-validation-for="Password"></span><br />

    <input asp-for="ConfirmPassword" type="password" placeholder="Confirm Password" />
    <span asp-validation-for="ConfirmPassword"></span><br />

    <button type="submit">Register</button>
</form>