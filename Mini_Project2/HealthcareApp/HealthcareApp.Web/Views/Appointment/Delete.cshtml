@model HealthcareApp.BLL.DTOs.AppointmentDto

<h3>Delete Appointment</h3>

<p>Are you sure you want to delete this appointment?</p>

<div>
    <b>Patient:</b> @Model.PatientName <br />
    <b>Doctor:</b> @Model.DoctorName <br />
    <b>Date:</b> @Model.Date.ToShortDateString() <br />
    <b>Time:</b> @Model.TimeSlot
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.AppointmentId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>